# ─────────────────────────────────────────────────────────────────────────────
# AICRA — Environment Configuration Template
# Copy this file to config/.env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──
SECRET_KEY=change-me-to-a-random-secret-key
FLASK_DEBUG=False

# ── MySQL ──
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_db_password_here
MYSQL_DATABASE=ai_code_review

# ─────────────────────────────────────────────────────────────────────────────
# AI PROVIDER — choose ONE block below and set AI_PROVIDER accordingly
# Options: custom | openai | anthropic | gemini | vertexai | gemini_cli
# ─────────────────────────────────────────────────────────────────────────────
AI_PROVIDER=custom

# ── Custom AI Bridge (AI_PROVIDER=custom) ──
# Any HTTP endpoint that accepts {"prompt": "..."} and returns {"response": "..."}
CUSTOM_AI_URL=http://your-bridge-host:3001/ask
CUSTOM_AI_USER=your_username
CUSTOM_AI_PASSWORD=your_password

# ── OpenAI (AI_PROVIDER=openai) ──
OPENAI_API_KEY=sk-...
OPENAI_FAST_MODEL=gpt-4o-mini
OPENAI_POWERFUL_MODEL=gpt-4o

# ── Anthropic Claude (AI_PROVIDER=anthropic) ──
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_FAST_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_POWERFUL_MODEL=claude-sonnet-4-6

# ── Google Gemini SDK (AI_PROVIDER=gemini) ──
# Get API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ── Google Vertex AI (AI_PROVIDER=vertexai) ──
# Requires: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# ── Gemini CLI (AI_PROVIDER=gemini_cli) ──
GEMINI_CLI_BIN=gemini
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ─────────────────────────────────────────────────────────────────────────────

# ── GitHub ──
GITHUB_TOKEN=ghp_your_token_here
GITHUB_ORG=your-org-name

# ── SonarQube ──
SONAR_HOST=http://localhost:9000
SONAR_TOKEN=sqp_your_token_here
SCANNER_PATH=/path/to/sonar-scanner/bin/sonar-scanner
SONAR_JAVA_HOME=/opt/homebrew/opt/openjdk@17

# ── Jira ──
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_DEFAULT_ENVIRONMENT=UAT
JIRA_DEFAULT_PROJECT=

# ── Temperature ──────────────────────────────────────────────────────────────
# AI_TEMPERATURE      = for analytical tasks (code review, risk scoring)
# AI_TEMPERATURE_JSON = for structured-output tasks (document parsing, JSON)
AI_TEMPERATURE=0.2
AI_TEMPERATURE_JSON=0.1

# ── Limits ──
MAX_ISSUES_FOR_AI=60
