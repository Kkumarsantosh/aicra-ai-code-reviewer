# .env configuration for AI Code Review System

# SonarQube Configuration
SONAR_HOST_URL=http://localhost:9000
SONAR_TOKEN=sqp_your_token_here
SONAR_PROJECT_KEY=your_project_key
SONAR_SCANNER_BIN=sonar-scanner

# AI / Gemini Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Workspace & Paths
WORKSPACE_PATH=/ai-code-review/workspace
REPORTS_PATH=/ai-code-review/reports
GITHUB_TOKEN=your_github_token_for_private_repos

# Python Configuration
PYTHON_BIN=/ai-code-review/.venv/bin/python

# Maximum issues to send to Gemini (controls token cost)
MAX_ISSUES_FOR_AI=30

# Jira Configuration
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your_jira_api_token_here
JIRA_DEFAULT_ENVIRONMENT=ENVIRONMENT_NAME


# MySQL
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="password"
MYSQL_DATABASE="ai_code_review"

GEMINI_API_KEY=""

 
JIRA_URL="https://atlassian.net"
JIRA_EMAIL="your-email@company.com"
JIRA_API_TOKEN="your_jira_api_token_here"