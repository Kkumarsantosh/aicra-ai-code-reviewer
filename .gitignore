# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Secrets — NEVER commit these ─────────────────────────────────────────────
config/.env
.env
*.pem
*.key

# ── OS artefacts ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE / editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── AICRA runtime directories ────────────────────────────────────────────────
# Generated at runtime — do not commit
workspace/
reports/

# ── Large bundled binaries ────────────────────────────────────────────────────
# Download these locally; see README for setup instructions
lib/sonar-scanner-*/
lib/git-sizer-*/
lib/*.jar

# ── Logs & temp ───────────────────────────────────────────────────────────────
*.log
*.tmp
.temp_context.txt

# ── Legacy SQLite (replaced by MySQL) ────────────────────────────────────────
aicra.db
